# =============================================================================
# Paramount Media Operations MCP Server - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# Environment: development, staging, production
ENVIRONMENT=development

# Mock mode - uses generated data when true (safe for demos)
MOCK_MODE=true

# API authentication (optional -- leave empty for open access in dev)
API_SECRET_KEY=

# CORS allowed origins (comma-separated). Empty = permissive in dev.
ALLOWED_ORIGINS=

# =============================================================================
# ATLASSIAN CLOUD (Free Tier) - JIRA & Confluence
# Site: https://paramounthackathon.atlassian.net
# Get API token: https://id.atlassian.com/manage-profile/security/api-tokens
# =============================================================================
JIRA_ENABLED=true
JIRA_FORCE_LIVE=false
JIRA_API_URL=https://paramounthackathon.atlassian.net
JIRA_API_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-api-token-here
JIRA_PROJECT_KEY=PROD

# Confluence (same instance as JIRA for Cloud)
CONFLUENCE_API_URL=https://paramounthackathon.atlassian.net
CONFLUENCE_USERNAME=your-email@example.com
CONFLUENCE_API_TOKEN=your-api-token-here
CONFLUENCE_SPACE_KEY=OPS

# =============================================================================
# FIGMA (Enterprise Access)
# Get token: Settings > Account > Personal access tokens
# =============================================================================
FIGMA_ENABLED=true
FIGMA_ACCESS_TOKEN=your-figma-token
FIGMA_FILE_ID=your-file-id
FIGMA_TEAM_ID=your-team-id

# =============================================================================
# CONVIVA - Streaming QoE (Mock Mode for Demo)
# =============================================================================
CONVIVA_ENABLED=true
CONVIVA_API_URL=https://api.conviva.com/insights/2.4
CONVIVA_CUSTOMER_KEY=
CONVIVA_API_KEY=

# =============================================================================
# NEWRELIC - NerdGraph GraphQL API
# =============================================================================
NEWRELIC_ENABLED=true
NEWRELIC_API_URL=https://api.newrelic.com/graphql
NEWRELIC_API_KEY=NRAK-xxxxxxxxxxxxxxxxxxxx
NEWRELIC_ACCOUNT_ID=1234567

# =============================================================================
# DATADOG - Incidents, Monitors, APM, Logs
# =============================================================================
DATADOG_ENABLED=false
DD_API_KEY=
DD_APP_KEY=
DD_SITE=datadoghq.com

# =============================================================================
# OBSERVABILITY SOURCE (newrelic | datadog | both)
# =============================================================================
OBSERVABILITY_SOURCE=both

# =============================================================================
# TESTRAIL - Test case management
# =============================================================================
TESTRAIL_ENABLED=false
TESTRAIL_URL=https://yourorg.testrail.io
TESTRAIL_EMAIL=your-email@company.com
TESTRAIL_API_KEY=
TESTRAIL_PROJECT_ID=1
TESTRAIL_DEFAULT_SUITE_ID=10
TESTRAIL_RCA_SECTION_ID=42

# =============================================================================
# DYNATRACE (optional)
# =============================================================================
DYNATRACE_ENABLED=false
DYNATRACE_ENVIRONMENT_URL=
DYNATRACE_API_TOKEN=

# =============================================================================
# AI FEATURES
# =============================================================================
ENABLE_AI_INSIGHTS=true
ENABLE_ANOMALY_DETECTION=true
ENABLE_PREDICTIVE_ANALYTICS=true

# =============================================================================
# LOCAL LLM (patent-safe, no external API key required)
# =============================================================================
# LOCAL_LLM_URL=http://localhost:11434/api/generate
# LOCAL_LLM_MODEL=llama3

# =============================================================================
# RCA PIPELINE
# =============================================================================
RCA_DUPLICATE_WINDOW_DAYS=90
RCA_REVIEW_SLA_HOURS=24

# =============================================================================
# Server Configuration
# =============================================================================
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000
LOG_LEVEL=INFO
